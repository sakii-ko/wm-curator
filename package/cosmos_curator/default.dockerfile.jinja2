# syntax=docker/dockerfile:1
# Dockerfile template for cosmos-curator
#
# The dockerfile is templated so that we can provide different conda env information.
# Docs on docker best practices:
# - https://linuxhandbook.com/dockerize-python-apps/
# - https://uwekorn.com/2021/03/01/deploying-conda-environments-in-docker-how-to-do-it-right.html
# - https://cloud.google.com/architecture/best-practices-for-building-containers

ARG DEBIAN_FRONTEND=noninteractive

# ---------------------------------------------------------------------------
# Wheels builder stage: install pixi (and pre-download NVIDIA wheels in full mode)
# ---------------------------------------------------------------------------
FROM nvcr.io/nvidia/cuda:13.0.2-devel-ubuntu24.04 AS wheels-builder

ARG PIXI_VERSION=v0.68.0

SHELL ["/bin/bash", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates && rm -rf /var/lib/apt/lists/*

# Install pixi with curl into /opt/pixi without modifying PATH
RUN curl -fsSL https://pixi.sh/install.sh | PIXI_VERSION="${PIXI_VERSION}" PIXI_HOME=/opt/pixi PIXI_NO_PATH_UPDATE=1 sh

{% if not slim %}
# Downloads large NVIDIA CUDA wheels from pypi.nvidia.com into a BuildKit
# cache so pixi install can read them locally (avoiding its hardcoded 30s
# HTTP timeout).  /wheels-ready is a sentinel that the main stage bind-mounts
# to force this stage to run first.
COPY pixi.toml pixi.lock /tmp/pixi-setup/
RUN --mount=type=cache,id=pixi-nvidia-wheels,target=/pixi-cache/nvidia-wheels \
    mkdir -p /pixi-cache/nvidia-wheels && \
    grep -oP 'https://pypi\.nvidia\.com/[^\s"]+\.whl' /tmp/pixi-setup/pixi.lock | sort -u | while read -r url; do \
        if [[ ! "$url" =~ ^https://pypi\.nvidia\.com/[a-zA-Z0-9/_.-]+\.whl$ ]]; then \
            echo "WARNING: Skipping invalid URL: $url"; \
            continue; \
        fi; \
        filename=$(basename "$url") && \
        echo "Pre-downloading: $filename" && \
        curl -fsSL --retry 5 --retry-delay 3 --max-time 300 -C - -o "/pixi-cache/nvidia-wheels/$filename" "$url" || \
            echo "WARNING: Failed to download $filename"; \
    done && \
    echo "=== Pre-downloaded $(ls -1 /pixi-cache/nvidia-wheels/*.whl 2>/dev/null | wc -l) NVIDIA wheels ===" && \
    touch /wheels-ready
{% if 'seedvr' in envs %}
# SeedVR tarball: fetch here so the main image does not need curl (libcurl pulls krb5).
ARG SEEDVR_COMMIT=e4de8c2
RUN mkdir -p /opt/seedvr-artifacts \
    && curl -fsSL --retry 5 --retry-delay 3 --max-time 300 "https://github.com/ByteDance-Seed/SeedVR/archive/${SEEDVR_COMMIT}.tar.gz" \
        | tar xz -C /tmp \
    && mv /tmp/SeedVR-${SEEDVR_COMMIT}* /opt/seedvr-artifacts/SeedVR
{% endif %}
{% endif %}

# ---------------------------------------------------------------------------
# Main stage
# ---------------------------------------------------------------------------
FROM nvcr.io/nvidia/cuda:13.0.2-devel-ubuntu24.04 AS main

SHELL ["/bin/bash", "-c"]
ENV NVIDIA_DRIVER_CAPABILITIES=compute,video,utility
ENV TZ=America/Los_Angeles
# Get system level packages
RUN apt-get update \
    && apt-get install --no-install-recommends --option=Dpkg::Options::=--force-confdef -y \
    # Needed because the certs age out sometimes?
    ca-certificates \
{%- if nsight %}
    # Needed for cuda profiling
    nsight-systems-2025.3.2 \
{%- endif %}
    # Needed to copy model weights using rclone
    rclone \
    # Refresh GPG-related base packages without reintroducing full build tooling
    keyboxd gpgv gpgsm gpgconf gpg-agent \
    binutils openssl libsqlite3-0 \
    && update-ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Triton 3.6+ looks for a separate "ptxas-blackwell" binary on Blackwell GPUs
# (arch >= 100). The CUDA toolkit ships a single ptxas that already supports
# Blackwell, so a symlink is sufficient.
RUN ln -sf /usr/local/cuda/bin/ptxas /usr/local/cuda/bin/ptxas-blackwell

# Copy pixi binary from the wheels-builder stage
COPY --from=wheels-builder /opt/pixi/bin/pixi /usr/local/bin/pixi

# Common ENV variables needed by some ML libs
ENV AM_I_DOCKER=True \
    BUILD_WITH_CUDA=True \
    TORCH_CUDA_ARCH_LIST="8.0;8.6;9.0;10.0+PTX" \
    CUDA_HOME="/usr/local/cuda" \
    CUDA_PATH="/usr/local/cuda" \
    PATH="/usr/local/cuda/bin:${PATH}" \
    CPATH="/usr/local/cuda/include" \
    LIBRARY_PATH="/usr/local/cuda/lib64:${LIBRARY_PATH:-}" \
    LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-}" \
    XFORMERS_IGNORE_FLASH_VERSION_CHECK="1" \
    VLLM_WORKER_MULTIPROC_METHOD="spawn"

# Disable Ray log dedup
ENV RAY_DEDUP_LOGS=0 \
    RAY_EXPERIMENTAL_NOSET_CUDA_VISIBLE_DEVICES=1 \
    RAY_MAX_LIMIT_FROM_API_SERVER=40000 \
    RAY_MAX_LIMIT_FROM_DATA_SOURCE=40000 \
    RAY_DEFAULT_OBJECT_STORE_MAX_MEMORY_BYTES=800000000000 \
    RAY_DEFAULT_OBJECT_STORE_MEMORY_PROPORTION=0.4 \
    RAY_gcs_rpc_server_connect_timeout_s=30 \
    RAY_gcs_rpc_server_reconnect_timeout_s=180 \
    RAY_WARN_BLOCKING_GET_INSIDE_ASYNC=0 \
    XENNA_RAY_METRICS_PORT=9002

# boto3 & pbss
ENV AWS_REQUEST_CHECKSUM_CALCULATION='when_required'

# Set a bunch of env vars so that we cache weights in a workspace
ENV DEFAULT_WORKSPACE_LOC="/config/default_workspace"
ENV HF_HOME="${DEFAULT_WORKSPACE_LOC}/weights/hf_home/" \
    LAION_CACHE_HOME="${DEFAULT_WORKSPACE_LOC}/weights/laion_cache/"

# Set up pixi environments
COPY --chown=1000:1000 pixi.toml pixi.lock {{code_dir_str}}/

{% if not slim %}
# ============================================================================
# NVIDIA CUDA Wheel Pre-download & pixi.lock Patching
# ============================================================================
#
# Problem:
#   pixi embeds uv as a compiled Rust library that hardcodes a 30-second HTTP
#   timeout for package downloads. This timeout CANNOT be configured:
#     - UV_HTTP_TIMEOUT env var is ignored (pixi overrides it internally)
#     - find-links / extra-index-urls are ignored during --frozen install
#       (pixi uses the exact download URLs baked into pixi.lock)
#
#   Large NVIDIA CUDA wheels (100-800 MB each) hosted on pypi.nvidia.com
#   regularly exceed 30 seconds to download, causing pixi install to fail.
#
# Solution:
#   1. Parse pixi.lock for all pypi.nvidia.com wheel URLs
#   2. Pre-download them with curl in wheels-builder (5-minute timeout, 5 retries)
#      into a named BuildKit cache (id=pixi-nvidia-wheels)
#   3. Patch pixi.lock in-place: replace remote URLs with file:// paths
#   4. pixi install --frozen reads the patched lockfile and loads wheels locally
#
# The pre-downloaded wheels live only in the BuildKit cache (id=pixi-nvidia-wheels)
# which persists across builds and does NOT bloat the Docker image layers.
# /wheels-ready is a sentinel bind-mounted from wheels-builder to force ordering.
#
#   +------------------+       +-------------------+       +---------------------+
#   |   pixi.lock      | grep  | pypi.nvidia.com   | curl  | BuildKit cache:     |
#   |   (lockfile)     +------>| wheel URLs        +------>| pixi-nvidia-wheels  |
#   +------------------+       +-------------------+       +---------------------+
#                                                                   |
#   +------------------+   sed replaces remote URLs                 |
#   |   pixi.lock      |   with file:///pixi-cache/nvidia-wheels/  |
#   |   (patched)      +<------------------------------------------+
#   +------------------+
#          |
#          |  pixi install --frozen
#          v
#   +------------------+
#   |  local .whl read |  (no network, no timeout)
#   +------------------+
# ============================================================================
RUN --mount=type=bind,from=wheels-builder,source=/wheels-ready,target=/tmp/wheels-ready \
    --mount=type=cache,id=pixi-nvidia-wheels,target=/pixi-cache/nvidia-wheels,readonly \
    cd {{code_dir_str}} && \
    patched=0 && \
    for whl in /pixi-cache/nvidia-wheels/*.whl; do \
        [ -f "$whl" ] || continue; \
        filename=$(basename "$whl") && \
        if grep -q "$filename" pixi.lock; then \
            sed -i "s|https://pypi\.nvidia\.com/[^\"]*/${filename}\\b|file:///pixi-cache/nvidia-wheels/${filename}|g" pixi.lock && \
            patched=$((patched + 1)); \
        fi; \
    done && \
    echo "=== Patched $patched NVIDIA wheel URLs in pixi.lock to use local files ==="

# If we install all the environments in a single layer, it's over 20GB and will cause slurm/NVCF to timeout pulling the
# layer. Since the cuml environment is large and needs non-overlapping RAPIDS packages, we install it separately.
#
# Same sentinel bind + readonly cache mount as the patch step above, so pixi
# install can resolve the patched file:// URLs locally.
#
# Retry logic: pixi install can fail due to transient network errors (connection resets, timeouts).
# We retry up to 10 times with a 3-second backoff to handle these flakes.
#
# IMPORTANT: Do NOT set RATTLER_CACHE_DIR or UV_CACHE_DIR to a BuildKit cache mount.
# Rattler uses hardlinks from its package cache into each environment directory. When
# multiple environments share packages (e.g. torch across default, unified, transformers),
# the hardlinked files share a single inode and Docker stores the data ONCE in the layer tar.
# Redirecting the cache to a mount (different filesystem) breaks hardlinks -- rattler falls
# back to full copies, duplicating multi-GB packages across every environment (~8GB -> ~21GB).
# Instead, let rattler use its default on-disk cache and clean it within the same RUN layer.
RUN --mount=type=bind,from=wheels-builder,source=/wheels-ready,target=/tmp/wheels-ready \
    --mount=type=cache,id=pixi-nvidia-wheels,target=/pixi-cache/nvidia-wheels,readonly \
    cd {{code_dir_str}} && \
{%- if verbose %}
    echo "=== pixi version ===" && pixi --version && \
{%- endif %}
    export CONDA_OVERRIDE_CUDA=13.0.2 && \
{%- if verbose %}
    export RUST_LOG=uv=debug && \
    export UV_NO_PROGRESS=1 && \
    export NO_COLOR=1 && \
{%- endif %}
    export CUDA_PATH="/usr/local/cuda" && \
    success=false && \
    for attempt in {1..10}; do \
        echo "=== pixi install attempt $attempt/10 ===" && \
        if pixi install {{ '-v' if verbose else '' }} -e {{ envs | reject('equalto', 'cuml') | join(' -e ') }} --frozen 2>&1; then \
            success=true && break; \
        fi; \
        echo "pixi install attempt $attempt/10 failed, retrying in 3s..." && sleep 3; \
    done && \
    pixi clean cache -y && \
    $success

# Install the cuml environment separately if requested.
{% if 'cuml' in envs %}
RUN --mount=type=bind,from=wheels-builder,source=/wheels-ready,target=/tmp/wheels-ready \
    --mount=type=cache,id=pixi-nvidia-wheels,target=/pixi-cache/nvidia-wheels,readonly \
    cd {{code_dir_str}} && \
    export CONDA_OVERRIDE_CUDA=13.0.2 && \
{%- if verbose %}
    export RUST_LOG=uv=debug && \
    export UV_NO_PROGRESS=1 && \
    export NO_COLOR=1 && \
{%- endif %}
    success=false && \
    for attempt in {1..10}; do \
        echo "=== pixi install cuml attempt $attempt/10 ===" && \
        if pixi install {{ '-v' if verbose else '' }} -e cuml --frozen 2>&1; then \
            success=true && break; \
        fi; \
        echo "pixi install attempt $attempt/10 failed, retrying in 3s..." && sleep 3; \
    done && \
    pixi clean cache -y && \
    $success
{% endif %}{# cuml #}

# Run any hacky post-install script for each environment
COPY package/cosmos_curator/envs/ /tmp/cosmos_curator_build_envs
{% for env in post_install_envs %}
RUN cd {{code_dir_str}} && \
    pixi run --as-is -e {{ env }} bash /tmp/cosmos_curator_build_envs/{{ env }}/post_install.sh
{% endfor %}

{% if 'seedvr' in envs %}
COPY --chown=1000:1000 --from=wheels-builder /opt/seedvr-artifacts/SeedVR {{code_dir_str}}/SeedVR
COPY cosmos_curator/pipelines/video/super_resolution/color_fix.py \
     {{code_dir_str}}/SeedVR/projects/video_diffusion_sr/color_fix.py
ENV SEEDVR_ROOT={{code_dir_str}}/SeedVR
{% endif %}

# For cosmos-xenna development.
# Requires a pre-built manylinux wheel matching THIS image's architecture
# (x86_64 or aarch64), placed at one of:
#   <repo-root>/target/wheels/cosmos_xenna-*manylinux*_<arch>.whl
#       (canonical / CI)
#   <repo-root>/cosmos-xenna/target/wheels/cosmos_xenna-*manylinux*_<arch>.whl
#       (maturin default when building inside the cosmos-xenna submodule)
# where <arch> is the value of `uname -m` evaluated inside the build (i.e.
# `x86_64` for amd64 images, `aarch64` for arm64 images such as GH200/GB200).
#
# Both wheel directories are copied into the image; install/check then narrows
# to the manylinux wheel matching the runtime architecture only. This is
# important when the host's target/wheels/ contains additional artifacts for
# other targets (e.g. a `macosx_*_arm64` wheel left behind by a local
# `maturin build` on macOS, or both x86_64 and aarch64 manylinux wheels built
# side-by-side) -- non-matching wheels are silently ignored, never installed.
#
# cosmos-xenna is a maturin/pyo3 (Rust) package; this image does NOT ship a
# Rust toolchain, so a source install would fail. Build the wheel on the host
# first for the correct target, e.g.:
#
#   cd <cosmos-xenna source> && uv sync --group dev && \
#       uv run maturin build --release --strip \
#           --compatibility manylinux_2_35 \
#           --target x86_64-unknown-linux-gnu --zig    # for amd64 images
#       # or:
#       uv run maturin build --release --strip \
#           --compatibility manylinux_2_35 \
#           --target aarch64-unknown-linux-gnu --zig   # for arm64 images
#
{% if use_local_xenna_build %}
COPY ["targe[t]/whee[l]s/", "cosmos-xenn[a]/targe[t]/whee[l]s/", "/tmp/cosmos-xenna-wheels/"]
RUN ARCH="$(uname -m)" && \
    ls /tmp/cosmos-xenna-wheels/cosmos_xenna-*manylinux*_${ARCH}.whl >/dev/null 2>&1 \
    || { echo "ERROR: no cosmos-xenna manylinux ${ARCH} wheel found in target/wheels/ or cosmos-xenna/target/wheels/."; \
         echo "Found these wheels (none usable for this image, arch=${ARCH}):"; \
         ls /tmp/cosmos-xenna-wheels/ 2>/dev/null || echo "  (no wheels directory at all)"; \
         echo "Build a manylinux ${ARCH} wheel on the host first."; \
         exit 1; }
{% for env in envs %}
RUN ARCH="$(uname -m)" && \
    cd {{code_dir_str}} && \
    pixi run --as-is -e {{ env }} pip uninstall -y cosmos-xenna && \
    pixi run --as-is -e {{ env }} pip install /tmp/cosmos-xenna-wheels/cosmos_xenna-*manylinux*_${ARCH}.whl
{% endfor %}
{% endif %}

{% endif %}{# not slim #}

{% if slim %}
# Slim image: store the environments for runtime installation.
# The launch flow reads this variable and runs pixi install --frozen before the user command.
ENV COSMOS_CURATOR_SLIM_ENVS="{{ envs | join(',') }}"
LABEL cosmos-curator.slim="true"
{% endif %}

# Copy the video pipeline code
COPY --chown=1000:1000 cosmos_curator {{code_dir_str}}/cosmos_curator
COPY --chown=1000:1000 tests {{code_dir_str}}/tests
COPY --chown=1000:1000 pytest.ini .coveragerc {{code_dir_str}}/
COPY --chown=1000:1000 README.md ATTRIBUTIONS.md {{code_dir_str}}/

# Copy additional code paths into the container
{% for code_path in code_paths %}
COPY --chown=1000:1000 {{code_path}} {{code_dir_str}}/{{code_path}}
{% endfor %}

# Debug env vars
# ENV PYTHON_LOG=debug RUST_LOG=debug VLLM_LOG_LEVEL=DEBUG

# Expose port for FastAPI & Ray
EXPOSE 8000 6379

WORKDIR {{code_dir_str}}

CMD ["pixi", "run", "--as-is", "python", "cosmos_curator/scripts/onto_nvcf.py", "--helm", "True"]
